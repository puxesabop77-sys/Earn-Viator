{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/EarnViator.html" },
    { "source": "/game", "destination": "/EarnViator.html" },
    { "source": "/wallet", "destination": "/EarnViator.html" },
    { "source": "/terms", "destination": "/EarnViator.html" },
    { "source": "/sufiyan", "destination": "/sufiyan.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
